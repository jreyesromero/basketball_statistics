# Copy to .env in this folder (optional). docker compose loads .env automatically.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me

# If log files do not appear inside Promtail (empty bind mount on Colima), set an
# absolute host path to the repo's data/logs directory, e.g.:
# BASKET_DATA_LOGS_HOST_PATH=/Users/you/workspace/personal/basketball_statistics/data/logs
